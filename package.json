{
  "name": "minimal-agent-ts",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "TypeScript agent harness evolved from context/event-structure experiments (ReAct, pointerize, spawn, TUI)",
  "scripts": {
    "start": "tsx src/main.ts",
    "tui": "tsx src/tui/main.ts",
    "web": "tsx src/web-cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "NODE_ENV=test node --import tsx --test tests/**/*.test.ts",
    "test:one": "NODE_ENV=test node --import tsx --test",
    "spawn:list": "tsx src/spawn-cli.ts list",
    "spawn:status": "tsx src/spawn-cli.ts status",
    "spawn:kill": "tsx src/spawn-cli.ts kill",
    "spawn:tail": "tsx src/spawn-cli.ts tail"
  },
  "devDependencies": {
    "@types/dotenv-safe": "^9.1.0",
    "@types/jszip": "^3.4.0",
    "@types/node": "^22.15.3",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@earendil-works/pi-tui": "^0.80.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "chalk": "^5.6.2",
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "linkedom": "^0.18.12",
    "mammoth": "^1.12.0",
    "pptxgenjs": "^4.0.1",
    "turndown": "^7.2.4",
    "ws": "^8.21.1"
  }
}
