{
  "name": "minimal-agent-ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Minimal ReAct agent loop in TypeScript for learning",
  "scripts": {
    "start": "tsx src/main.ts",
    "tui": "tsx src/tui/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "NODE_ENV=test node --import tsx --test tests/**/*.test.ts",
    "p0:summary": "tsx src/p0-summary.ts",
    "p0:compare": "tsx src/p0-compare.ts"
  },
  "devDependencies": {
    "@types/dotenv-safe": "^9.1.0",
    "@types/node": "^22.15.3",
    "@types/turndown": "^5.0.6",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@earendil-works/pi-tui": "^0.80.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@xenova/transformers": "^2.17.2",
    "@zvec/zvec": "^0.5.0",
    "chalk": "^5.6.2",
    "dotenv": "^17.4.2",
    "linkedom": "^0.18.12",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "turndown": "^7.2.4"
  }
}
