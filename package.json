{
  "name": "minimal-agent-ts",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Minimal ReAct agent loop in TypeScript for learning",
  "scripts": {
    "start": "tsx src/main.ts",
    "tui": "tsx src/tui/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "NODE_ENV=test node --import tsx --test tests/**/*.test.ts",
    "test:one": "NODE_ENV=test node --import tsx --test",
    "spawn:list": "tsx src/spawn-cli.ts list",
    "spawn:status": "tsx src/spawn-cli.ts status",
    "spawn:kill": "tsx src/spawn-cli.ts kill",
    "spawn:tail": "tsx src/spawn-cli.ts tail"
  },
  "devDependencies": {
    "@types/dotenv-safe": "^9.1.0",
    "@types/node": "^22.15.3",
    "@types/turndown": "^5.0.6",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@earendil-works/pi-tui": "^0.80.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "chalk": "^5.6.2",
    "dotenv": "^17.4.2",
    "linkedom": "^0.18.12",
    "turndown": "^7.2.4"
  }
}
