{
  "_llm_comment": "KEYS: put secrets in .env only (see .env.example). This file points at env var NAMES via api_key_env — never paste sk- here. Default profile deepseek-main → DEEPSEEK_API_KEY. Fallback openrouter-test → OPENROUTER_API_KEY. Templates: agent.llm.2key.example.json / agent.llm.example.json",
  "default_api_profile": "deepseek-main",
  "api_profiles": {
    "deepseek-main": {
      "display_name": "DeepSeek V4（官方）",
      "base_url": "https://api.deepseek.com",
      "api_key_env": "DEEPSEEK_API_KEY",
      "_key_hint": "Set DEEPSEEK_API_KEY=... in .env (not in this file)",
      "default_model": "deepseek-v4-flash",
      "models": ["deepseek-v4-flash", "deepseek-v4-pro"],
      "fallback_profiles": ["openrouter-test"],
      "cache": { "mode": "implicit", "telemetry": true },
      "reasoning_map": {
        "low": {
          "thinking": { "type": "enabled" },
          "reasoning_effort": "low"
        },
        "medium": {
          "thinking": { "type": "enabled" },
          "reasoning_effort": "medium"
        },
        "high": {
          "thinking": { "type": "enabled" },
          "reasoning_effort": "high"
        }
      }
    },
    "openrouter-test": {
      "display_name": "OpenRouter（备用）",
      "base_url": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY",
      "_key_hint": "Optional fallback — set OPENROUTER_API_KEY=... in .env",
      "default_model": "deepseek/deepseek-v4-flash",
      "models": [
        "deepseek/deepseek-v4-flash",
        "deepseek/deepseek-v4-pro",
        "x-ai/grok-4.5"
      ],
      "cache": {
        "mode": "openrouter_sticky",
        "session_id_from": "session_id"
      },
      "extra_body": {
        "provider": {
          "order": ["DeepSeek"],
          "allow_fallbacks": true
        }
      }
    }
  },
  "builtin_tools": [
    "read_file",
    "write_file",
    "edit_file",
    "apply_patch",
    "grep_search",
    "list_files",
    "diff_file",
    "recall_query",
    "invoke_skill",
    "run_shell",
    "test_run",
    "git_status",
    "git_diff",
    "git_log",
    "lsp_query",
    "office_read",
    "office_write",
    "web_fetch",
    "web_search",
    "spawn_agent",
    "spawn_background",
    "code_review"
