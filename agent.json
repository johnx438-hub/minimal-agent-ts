{
  "_llm_comment": "Active config: deepseek-main (default) + openrouter-test (fallback). Keys in .env only. Template: agent.llm.2key.example.json | Full multi-vendor: agent.llm.example.json",
  "default_api_profile": "deepseek-main",
  "api_profiles": {
    "deepseek-main": {
      "display_name": "DeepSeek V4（官方）",
      "base_url": "https://api.deepseek.com",
      "api_key_env": "DEEPSEEK_API_KEY",
      "default_model": "deepseek-v4-flash",
      "models": ["deepseek-v4-flash", "deepseek-v4-pro"],
      "fallback_profiles": ["openrouter-test"],
      "cache": { "mode": "implicit", "telemetry": true },
      "reasoning_map": {
        "low": {
          "thinking": { "type": "enabled" },
          "reasoning_effort": "low"
        },
        "medium": {
          "thinking": { "type": "enabled" },
          "reasoning_effort": "medium"
        },
        "high": {
          "thinking": { "type": "enabled" },
          "reasoning_effort": "high"
        }
      }
    },
    "openrouter-test": {
      "display_name": "OpenRouter（备用）",
      "base_url": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY",
      "default_model": "deepseek/deepseek-v4-flash",
      "models": [
        "deepseek/deepseek-v4-flash",
        "deepseek/deepseek-v4-pro",
        "x-ai/grok-4.5"
      ],
      "cache": {
        "mode": "openrouter_sticky",
        "session_id_from": "session_id"
      },
      "extra_body": {
        "provider": {
          "order": ["DeepSeek"],
          "allow_fallbacks": true
        }
      }
    }
  },
  "builtin_tools": [
    "read_file",
    "write_file",
    "edit_file",
    "grep_search",
    "list_files",
    "diff_file",
    "recall_query",
    "invoke_skill",
    "run_shell",
    "web_fetch",
    "web_search",
    "spawn_agent",
    "spawn_background",
    "code_review"
  ],
  "spawn_policy": {
    "max_parallel": 3,
    "max_turns_default": 15,
    "max_turns_cap": 80
  },
  "spawn_presets": [
    {
      "name": "dev-worker",
      "description": "Full-tools coding worker (read/write/edit/shell/web); no nested spawn — for parallel implement/fix jobs",
      "prompt_file": "agents/dev-worker.md",
      "tools": [
        "read_file",
        "write_file",
        "edit_file",
        "grep_search",
        "list_files",
        "diff_file",
        "recall_query",
        "invoke_skill",
        "run_shell",
        "web_fetch",
        "web_search"
      ],
      "max_turns": 50
    },
    {
      "name": "web-researcher",
      "description": "Delegate web lookup and source summaries",
      "prompt_file": "agents/web-researcher.md",
      "tools": ["web_fetch", "read_file", "grep_search", "write_file"]
    },
    {
      "name": "skeleton-reader",
      "description": "Read-only repo skeleton and entry-point map",
      "prompt_file": "agents/skeleton-reader.md",
      "tools": ["read_file", "grep_search", "list_files", "diff_file"]
    },
    {
      "name": "hackernews-digest",
      "description": "Fetch HN post URLs and return a short digest",
      "prompt_file": "agents/hackernews-digest.md",
      "tools": ["web_fetch", "read_file", "write_file"]
    },
    {
      "name": "code-review-bug",
      "description": "Fast diff-first bug pass — logic/async/error-handling in changed hunks",
      "prompt_file": "agents/code-review-bug.md",
      "tools": ["read_file", "grep_search", "write_file"],
      "max_turns": 20
    },
    {
      "name": "code-review-security",
      "description": "Review code for security vulnerabilities, secrets, injection risks",
      "prompt_file": "agents/code-review-security.md",
      "tools": ["read_file", "grep_search", "write_file"],
      "max_turns": 20
    },
    {
      "name": "code-review-quality",
      "description": "Review code for readability, consistency, and best practices",
      "prompt_file": "agents/code-review-quality.md",
      "tools": ["read_file", "grep_search", "write_file"],
      "max_turns": 20
    }
  ],
  "skills_dirs": ["./skills"],
  "loaded_skills": [],
  "pointerize_policy": {
    "keep_inline_turns": 2,
    "preview_min_chars": 120,
    "preview_max_chars": 480,
    "preview_ratio": 0.04,
    "preview_mode": "smart",
    "preview_max_lines": 5,
    "summary_max_chars": 120
  },
  "recall_policy": {
    "auto_full_max_chars": 24000
  },
  "web_search": {
    "allowed": true,
    "backend": "ddgr",
    "max_results_default": 5,
    "max_results_cap": 10,
    "cache": { "enabled": true, "search_spill_dir": ".cache/web-fetch" },
    "budget": { "max_external_per_task": 5, "warn_after": 3 }
  },
  "web_fetch_policy": {
    "allow_domains": ["*"],
    "deny_domains": [],
    "default_timeout_ms": 15000,
    "cloak_timeout_ms": 90000,
    "max_chars": 80000,
    "cloak_fetch_enabled": false,
    "cloak_fetch_script": "skills/cloak-fetch/cloak_fetch.py"
  },
  "mcp_policy": {
    "allow": ["*"],
    "deny": []
  },
  "mcp_servers": []
}