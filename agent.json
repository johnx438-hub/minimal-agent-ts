  "spawn_policy": {
    "max_parallel": 3,
    "max_turns_default": 15,
    "max_turns_cap": 80,
    "shell": {
      "mode": "deny_only",
      "deny_patterns": [
        "\\brm\\s+(-[a-zA-Z]*f[a-zA-Z]*\\s+)?/",
        "\\bsudo\\b",
        "\\bmkfs\\b",
        "curl\\s+.*\\|\\s*(ba)?sh",
        "wget\\s+.*\\|\\s*(ba)?sh",
        ">\\s*/etc/",
        "\\bdd\\s+if="
      ],
      "timeout_ms_cap": 300000
    }
  },
  "spawn_presets": [
