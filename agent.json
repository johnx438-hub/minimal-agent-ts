{
  "builtin_tools": [
    "read_file",
    "write_file",
    "edit_file",
    "grep_search",
    "list_files",
    "diff_file",
    "recall_query",
    "invoke_skill",
    "run_shell",
    "web_fetch",
    "spawn_agent",
    "spawn_background",
    "code_review"
  ],
  "spawn_policy": {
    "max_parallel": 3,
    "max_turns_default": 15,
    "max_turns_cap": 30
  },
  "spawn_presets": [
    {
      "name": "web-researcher",
      "description": "Delegate web lookup and source summaries",
      "prompt_file": "agents/web-researcher.md",
      "tools": ["web_fetch", "read_file", "grep_search", "write_file"]
    },
    {
      "name": "skeleton-reader",
      "description": "Read-only repo skeleton and entry-point map",
      "prompt_file": "agents/skeleton-reader.md",
      "tools": ["read_file", "grep_search", "list_files", "diff_file"]
    },
    {
      "name": "hackernews-digest",
      "description": "Fetch HN post URLs and return a short digest",
      "prompt_file": "agents/hackernews-digest.md",
      "tools": ["web_fetch", "read_file", "write_file"]
    },
    {
      "name": "code-review-bug",
      "description": "Fast diff-first bug pass — logic/async/error-handling in changed hunks (≤6 tool calls)",
      "prompt_file": "agents/code-review-bug.md",
      "tools": ["read_file", "grep_search", "write_file"],
      "max_turns": 12
    },
    {
      "name": "code-review-security",
      "description": "Review code for security vulnerabilities, secrets, injection risks",
      "prompt_file": "agents/code-review-security.md",
      "tools": ["read_file", "grep_search", "write_file"],
      "max_turns": 12
    },
    {
      "name": "code-review-quality",
      "description": "Review code for readability, consistency, and best practices",
      "prompt_file": "agents/code-review-quality.md",
      "tools": ["read_file", "grep_search", "write_file"],
      "max_turns": 12
    }
  ],
  "skills_dirs": ["./skills"],
  "loaded_skills": [],
  "pointerize_policy": {
    "keep_inline_turns": 2,
    "preview_min_chars": 120,
    "preview_max_chars": 480,
    "preview_ratio": 0.04,
    "preview_mode": "smart",
    "preview_max_lines": 5,
    "summary_max_chars": 120
  },
  "recall_policy": {
    "auto_full_max_chars": 24000
  },
  "web_fetch_policy": {
    "allow_domains": ["*"],
    "deny_domains": [],
    "default_timeout_ms": 15000,
    "cloak_timeout_ms": 90000,
    "max_chars": 80000,
    "cloak_fetch_enabled": false,
    "cloak_fetch_script": "skills/cloak-fetch/cloak_fetch.py"
  },
  "mcp_policy": {
    "allow": ["*"],
    "deny": []
  },
  "mcp_servers": []
}