  "skills_dirs": ["./skills"],
  "loaded_skills": ["memory"],
  "pointerize_policy": {
    "keep_inline_turns": 2,
    "soft_force_ratio": 0.75,
    "tool_overrides": {
      "recall_query": { "mode": "never" },
      "read_file": { "keep_inline_turns": 6 }
    },
    "preview_min_chars": 120,
    "preview_max_chars": 480,
    "preview_ratio": 0.04,
    "preview_mode": "smart",
    "preview_max_lines": 5,
    "summary_max_chars": 120
  },
  "recall_policy": {
    "auto_full_max_chars": 24000
  },
  "web_search": {
    "allowed": true,
    "backend": "ddgr",
    "max_results_default": 5,
    "max_results_cap": 10,
    "cache": { "enabled": true, "search_spill_dir": ".cache/web-fetch" },
    "budget": { "max_external_per_task": 5, "warn_after": 3 }
  },
  "web_fetch_policy": {
    "allow_domains": ["*"],
    "deny_domains": [],
    "default_timeout_ms": 15000,
    "cloak_timeout_ms": 90000,
    "max_chars": 80000,
    "cloak_fetch_enabled": false,
    "cloak_fetch_script": "skills/cloak-fetch/cloak_fetch.py"
