        "\\bsudo\\b",
        "\\bmkfs\\b",
        "curl\\s+.*\\|\\s*(ba)?sh",
        "wget\\s+.*\\|\\s*(ba)?sh",
        ">\\s*/etc/",
        "\\bdd\\s+if="
