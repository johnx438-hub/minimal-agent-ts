{
  "_llm_comment": "LLM: secrets ONLY in .env (see .env.example). This file uses api_key_env as the ENV VAR NAME (not the key). Default deepseek-main → DEEPSEEK_API_KEY; fallback openrouter-test → OPENROUTER_API_KEY; kimi-main → MOONSHOT_API_KEY (vision + preserve_reasoning). Switch: default_api_profile or TUI /profile. Templates: agent.llm.example.json.",
  "default_api_profile": "deepseek-main",
  "api_profiles": {
    "deepseek-main": {
      "display_name": "DeepSeek V4（官方）",
      "base_url": "https://api.deepseek.com",
      "api_key_env": "DEEPSEEK_API_KEY",
      "_key_hint": "Any name works: set api_key_env then put that name in .env. Now: DEEPSEEK_API_KEY=... in .env",
      "default_model": "deepseek-v4-pro",
      "models": ["deepseek-v4-flash", "deepseek-v4-pro"],
      "fallback_profiles": ["openrouter-test"],
      "cache": { "mode": "implicit", "telemetry": true },
      "reasoning_map": {
        "low": {
          "thinking": { "type": "enabled" },
          "reasoning_effort": "low"
        },
        "medium": {
          "thinking": { "type": "enabled" },
          "reasoning_effort": "medium"
        },
        "high": {
          "thinking": { "type": "enabled" },
          "reasoning_effort": "high"
        }
      }
    },
    "openrouter-test": {
      "display_name": "OpenRouter（备用）",
      "base_url": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY",
      "_key_hint": "Optional fallback — OPENROUTER_API_KEY=... in .env (name matches api_key_env)",
      "default_model": "deepseek/deepseek-v4-flash",
      "models": [
        "deepseek/deepseek-v4-flash",
        "deepseek/deepseek-v4-pro",
        "x-ai/grok-4.5",
        "z-ai/glm-5.2"
      ],
      "cache": {
        "mode": "openrouter_sticky",
        "session_id_from": "session_id"
      },
      "extra_body": {
        "provider": {
          "order": ["DeepSeek"],
          "allow_fallbacks": true
        }
      }
    },
    "kimi-main": {
      "_note": "国内 platform.moonshot.cn 申请的 key 必须用 api.moonshot.cn；国际 platform.kimi.ai / platform.moonshot.ai 的 key 用 api.moonshot.ai（key 与 endpoint 不可混用，混用必 401）。.env: MOONSHOT_API_KEY=... 切换: /profile kimi-main。cache=prompt_cache_key + preserve_reasoning。",
      "display_name": "Kimi（Moonshot 国内）",
      "base_url": "https://api.moonshot.cn/v1",
      "api_key_env": "MOONSHOT_API_KEY",
      "_key_hint": "MOONSHOT_API_KEY from platform.moonshot.cn → base_url api.moonshot.cn；国际站 key → 改 base_url 为 https://api.moonshot.ai/v1",
      "default_model": "kimi-k2.6",
      "models": ["kimi-k2.6", "kimi-k3", "kimi-k2.7-code", "kimi-k2.7-code-highspeed"],
      "supports_vision": true,
      "preserve_reasoning": true,
      "cache": {
        "mode": "prompt_cache_key",
        "session_id_from": "session_id",
        "telemetry": true
      },
      "reasoning_map": {
        "low": {
          "thinking": { "type": "enabled", "keep": "all" }
        },
        "high": {
          "thinking": { "type": "enabled", "keep": "all" },
          "reasoning_effort": "max"
        }
      }
    }
  },
  "builtin_tools": [
    "read_file",
    "write_file",
    "edit_file",
    "apply_patch",
    "grep_search",
    "list_files",
    "diff_file",
    "recall_query",
