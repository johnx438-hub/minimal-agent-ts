# Dependencies
node_modules/

# Build output
dist/
out/

# Environment & secrets (never commit)
.env
.env.*
!.env.example
agent.llm.prepare.json

# Session runtime: conversations, cold storage, vector index
.sessions/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Logs & temp
*.log
npm-debug.log*
.cache/

# Local TUI prefs (test artifacts)
.tui-prefs.json
.tui-prefs-test.json
.tui-prefs.json.bak

# Local workspace / scratch (agent outputs, screenshots, jobs)
/workspace/
/web-articles/
CONVERSATION_SUMMARY.md
PROJECT_SUMMARY.md

# Dogfood notes accidentally written at repo root (prefer workspace/)
/reports/
/*-summary.md
/*-report.md
/workflow-module-analysis.md

# Zvec / local index artifacts (if created outside .sessions)
*.zvec
agent_memory.zvec

# Skills: ship thin SKILL.md only; full vendor trees (e.g. cli-web-search Cargo)
# stay local — install / clone under skills/ without polluting git status.
# skills/*/** re-ignores nested paths so a skill's own .gitignore cannot
# re-include Cargo.lock / src / etc.
skills/**
!skills/*/
!skills/*/SKILL.md
skills/*/**
!skills/*/SKILL.md
!skills/cloak-fetch/cloak_fetch.py

# User-level memory (personal — keep local)
.agent/memory/

# Rust / Windows junk under optional local skills
skills/**/target/
*:Zone.Identifier
