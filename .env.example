# Copy to .env and fill in your keys
OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# DEEPSEEK_API_KEY=          # agent.llm.example.json → deepseek-main
# ZAI_API_KEY=               # agent.llm.example.json → glm-main / review-cheap
# XAI_API_KEY=               # agent.llm.example.json → xai-test

OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
MODEL=YOUR_MODEL_NAME

MAX_TURNS=0
LOOP_GUARD=inject
LOOP_HARD_CEILING=200
# LOOP_GUARD_REGRESSION=1   # looser repeat detection (or prefix task with [regression])

# CloakFetch — anti-bot page fallback
# CLOAK_FETCH_SCRIPT=./skills/cloak-fetch/cloak_fetch.py

# MINIMAL_SHELL=/bin/bash   # optional: force run_shell executable (else SHELL → bash/sh → cmd on Windows)
# ALLOW_SHELL=1
# ALLOW_WEB=1
# MAX_CONTEXT_TOKENS=1000000
# AGENT_MD_MAX_CHARS=8000   # workspace Agent.md / AGENTS.md injection limit
# MEMORY_INJECT_MAX_CHARS=4096   # .agent/memory profile+requirements injection limit
# STREAM=1
# ENABLE_ZVEC=1   # deprecated opt-in: ZVEC semantic index (default off; removed in F3-c)
# ENABLE_EMBEDDINGS=0   # only when ENABLE_ZVEC=1
# SESSION_SAVE_MIN_INTERVAL_MS=30000

# P0 turn/IO telemetry → workspace/p0-telemetry/ (runs.jsonl + summary.tsv)
# P0_TELEMETRY=1
# P0_TELEMETRY=auto   # enable when ACTION_IO_METRICS=1
# ACTION_IO_METRICS=1