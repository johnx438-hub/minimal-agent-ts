# =============================================================================
#  密钥只写在本文件（复制为 .env 后填写）。不要把 sk- / key 写进 agent.json。
# =============================================================================
#
#  新人 3 步：
#    1)  cp .env.example .env
#    2)  在下面「必填」里贴上 API key
#    3)  npm run tui
#
#  ── 变量名硬不硬编码？──────────────────────────────────────────────────
#  有名 profile（推荐）：不硬编码。agent.json 里
#      "api_key_env": "DEEPSEEK_API_KEY"
#  表示「从本文件读同名变量」。你可改成任意名字，例如 MY_GATEWAY_KEY，
#  然后在本文件增加 MY_GATEWAY_KEY=sk-...
#
#  当前 profile 约定（可改 agent.json）：
#    deepseek-main      →  DEEPSEEK_API_KEY     （下面「必填」）
#    openrouter-test    →  OPENROUTER_API_KEY   （备用）
#    kimi-main          →  MOONSHOT_API_KEY    （视觉 / preserve_reasoning）
#
#  无 api_profiles 时的旧回退 __env__ 才会看 OPENAI_API_KEY / OPENROUTER_API_KEY
#  + OPENAI_BASE_URL + MODEL（一般用不到）。
#
#  ── 换自己的常用 API（OpenAI 兼容 chat/completions）──────────────────
#  1) agent.json 增加 profile，例如：
#       "my-gateway": {
#         "base_url": "https://your-gateway.example/v1",
#         "api_key_env": "MY_GATEWAY_KEY",
#         "default_model": "my-model-1",
#         "models": ["my-model-1"]
#       }
#     并设 "default_api_profile": "my-gateway"
#  2) 本文件写：  MY_GATEWAY_KEY=sk-xxxx
#  3) npm run tui   （或 /profile my-gateway）
#  模板：agent.llm.example.json / agent.llm.2key.example.json
# =============================================================================

# ── 必填（默认 default_api_profile = deepseek-main）────────────────────────
# 申请: https://platform.deepseek.com/
# 对应 agent.json → api_profiles.deepseek-main.api_key_env
DEEPSEEK_API_KEY=

# ── 推荐（fallback profile openrouter-test；主 key 挂了才用）──────────────
# 申请: https://openrouter.ai/keys
# 对应 agent.json → api_profiles.openrouter-test.api_key_env
OPENROUTER_API_KEY=

# ── Kimi / Moonshot（agent.json → kimi-main；TUI /profile kimi-main）──────
# 国内: https://platform.moonshot.cn/ → base_url 用 https://api.moonshot.cn/v1
# 国际: https://platform.kimi.ai/ 或 platform.moonshot.ai → https://api.moonshot.ai/v1
# 国内 key 打国际站 / 反之会 401 Invalid Authentication（key 与 endpoint 绑定）
# 对应 api_profiles.kimi-main.api_key_env
MOONSHOT_API_KEY=

# ── 自定义 profile：在 agent.json 设 api_key_env 后，在这里加同名变量 ────
# MY_GATEWAY_KEY=
# OPENAI_API_KEY=
# ZAI_API_KEY=
# XAI_API_KEY=

# =============================================================================
#  下面都是可选运行时开关（有默认值，可先不改）
# =============================================================================

# 是否从厂商 GET /models 补全 /model 列表（0=只用 agent.json 的 models[]）
# REMOTE_MODELS=0

# 主 profile 失败时是否走 fallback_profiles（默认开；设 0 禁用）
# FALLBACK=0

# 上下文预算 token（默认 200k；DeepSeek V4 官方窗口可达 1M）
MAX_CONTEXT_TOKENS=200000

# Agent 行为
MAX_TURNS=0
# headless 默认是否开 shell/web（TUI 另有 /shell /web 与 prefs）
ALLOW_SHELL=1
ALLOW_WEB=1
LOOP_GUARD=inject
LOOP_HARD_CEILING=200

# 其它按需
# STREAM=0
# ACTION_IO_METRICS=1
# CLOAK_FETCH_SCRIPT=./skills/cloak-fetch/cloak_fetch.py
# MINIMAL_SHELL=/bin/bash
