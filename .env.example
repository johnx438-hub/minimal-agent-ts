# =============================================================================
#  密钥只写在本文件（复制为 .env 后填写）。不要把 sk- / key 写进 agent.json。
# =============================================================================
#
#  新人 3 步：
#    1)  cp .env.example .env
#    2)  在下面「必填」里贴上 API key
#    3)  npm run tui
#
#  agent.json 里只有「用哪个环境变量名」，例如：
#    api_profiles.deepseek-main.api_key_env  →  DEEPSEEK_API_KEY
#    api_profiles.openrouter-test.api_key_env →  OPENROUTER_API_KEY
#  改模型列表 / 默认 profile → 编辑 agent.json（不是这里）。
# =============================================================================

# ── 必填（默认 default_api_profile = deepseek-main）────────────────────────
# 申请: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# ── 推荐（fallback profile openrouter-test；主 key 挂了才用）──────────────
# 申请: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── 若你把 default_api_profile 改成别的，再填对应变量 ────────────────────
# OPENAI_API_KEY=
# ZAI_API_KEY=
# XAI_API_KEY=

# =============================================================================
#  下面都是可选运行时开关（有默认值，可先不改）
# =============================================================================

# 是否从厂商 GET /models 补全 /model 列表（0=只用 agent.json 的 models[]）
# REMOTE_MODELS=0

# 主 profile 失败时是否走 fallback_profiles（默认开；设 0 禁用）
# FALLBACK=0

# 上下文预算 token（默认 200k；DeepSeek V4 官方窗口可达 1M）
MAX_CONTEXT_TOKENS=200000

# Agent 行为
MAX_TURNS=0
# headless 默认是否开 shell/web（TUI 另有 /shell /web 与 prefs）
ALLOW_SHELL=1
ALLOW_WEB=1
LOOP_GUARD=inject
LOOP_HARD_CEILING=200

# 其它按需
# STREAM=0
# ACTION_IO_METRICS=1
# CLOAK_FETCH_SCRIPT=./skills/cloak-fetch/cloak_fetch.py
# MINIMAL_SHELL=/bin/bash
