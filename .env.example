# Copy to .env and fill in your keys.
# ────────────────────────────────────────────────────────────────────
# Config map (轨 G)
#   agent.json     → api_profiles, default_api_profile, spawn, tools
#   .env           → secrets + runtime toggles (this file)
#   agent.llm.2key.example.json → LLM snippet reference (DeepSeek + OR)
# ────────────────────────────────────────────────────────────────────

# ── LLM keys（api_key_env 指向这些变量名，勿写进 agent.json）────────
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# OpenRouter GET /models 慢时关闭远程补全（/model 仅用 agent.json models[]）
REMOTE_MODELS=0

# 主 profile 失败时是否走 fallback_profiles 链（默认开启；设 0 禁用）
# FALLBACK=0

# ── 旧版 __env__ 回退（agent.json 已有 api_profiles 时主 Agent 不使用）──
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# MODEL=

# ── 上下文预算（context-budget.ts：env > 模型表 > 200k 默认，不向 API 探测）──
# DeepSeek V4 flash/pro 官方 1M（https://api-docs.deepseek.com/quick_start/pricing）
# 推荐 200000 作日常压缩预算；吃满窗口可设 1000000 或删除此行用模型表 1M
MAX_CONTEXT_TOKENS=200000

# ── Agent 行为 ─────────────────────────────────────────────────────
MAX_TURNS=0
ALLOW_SHELL=1
ALLOW_WEB=1
LOOP_GUARD=inject
LOOP_HARD_CEILING=200
# LOOP_GUARD_REGRESSION=1

# ── 可观测（headless / printStepEvent）──────────────────────────────
# ACTION_IO_METRICS=1

# ── 其他（按需取消注释）────────────────────────────────────────────
# STREAM=1
# AGENT_MD_MAX_CHARS=8000
# MEMORY_INJECT_MAX_CHARS=4096
# SESSION_SAVE_MIN_INTERVAL_MS=30000
# CLOAK_FETCH_SCRIPT=./skills/cloak-fetch/cloak_fetch.py
# MINIMAL_SHELL=/bin/bash